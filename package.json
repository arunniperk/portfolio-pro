{
  "name": "portfolio-manager-pro",
  "version": "6.0.0",
  "description": "Portfolio Manager Pro - Premium Asset Tracking",
  "author": "Arun Verma <arunmcops@gmail.com>",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "dist:win": "electron-builder --win --x64",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.portfolio.desktop",
    "productName": "Portfolio Manager Pro",
    "asar": true,
    "compression": "maximum",
    "files": [
      "build/**/*",
      "main.js",
      "preload.js"
    ],
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Finance"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "shortcutName": "Portfolio Manager Pro",
      "runAfterFinish": true,
      "perMachine": false
    },
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "arunniperk",
        "repo": "stock-portfolio-desktop",
        "private": false
      }
    ]
  }
}
